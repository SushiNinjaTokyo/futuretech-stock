<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock — Daily Top 10 ({{ date | default('', true) }})</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <style>
    /* そのまま（変更なし） */
    /* ※CSSは既存そのままでOK */
  </style>
</head>
<body>
<div class="wrap">

<header class="page">
  <h1>Daily Top 10</h1>
  <div class="date">Date: {{ date }}</div>
</header>

<section class="grid">

{% for item in (top10 or []) %}

{% set rk = loop.index %}
{% set sym = item.symbol or '' %}
{% set nm  = item.name or '' %}

{% set comps = item.score_components or {} %}

{% set vol = (comps.get("volume_anomaly") or 0) | float %}
{% set trd = (comps.get("trends_breakout") or 0) | float %}
{% set nws = (comps.get("news") or 0) | float %}

<article class="card rank-{{ rk }}" data-symbol="{{ sym }}">
  <span class="rank-badge">#{{ rk }}</span>

  <div class="hd">
    <div>
      <div class="sym">{{ sym }}</div>
      <div class="name">{{ nm }}</div>
    </div>

    <div class="scores">
      <div class="kpi">
        <div class="tt">Final Score</div>
        <div class="vv">
          {{ ((item.final_score_0_1 or 0) * 100) | round(1) }}
          <span class="sub">/100</span>
        </div>
      </div>

      <div class="kpi">
        <div class="tt">Points</div>
        <div class="vv">{{ item.score_pts or 0 }}</div>
      </div>

      <div class="kpi">
        <div class="tt">Δ Price</div>
        <div class="sub">
          1D: {{ item.price_delta_1d is not none and (item.price_delta_1d|round(2)|string + '%') or '—' }} /
          1W: {{ item.price_delta_1w is not none and (item.price_delta_1w|round(2)|string + '%') or '—' }} /
          1M: {{ item.price_delta_1m is not none and (item.price_delta_1m|round(2)|string + '%') or '—' }}
        </div>
      </div>
    </div>

    <div class="rocket">
      <span class="flame">🔥</span><span class="em">🚀</span>
    </div>
  </div>

  <div class="breakdown">

    <div class="row">
      <div class="lbl">Volume anomaly</div>
      <div class="bar"><i style="width: {{ (vol * 100) | round(1) }}%"></i></div>
      <div class="pct">{{ (vol * 100) | round(1) }}%</div>
    </div>

    <div class="row">
      <div class="lbl">Trends breakout</div>
      <div class="bar"><i style="width: {{ (trd * 100) | round(1) }}%"></i></div>
      <div class="pct">{{ (trd * 100) | round(1) }}%</div>
    </div>

    <div class="row">
      <div class="lbl">News</div>
      <div class="bar"><i style="width: {{ (nws * 100) | round(1) }}%"></i></div>
      <div class="pct">{{ (nws * 100) | round(1) }}%</div>
    </div>

    <div class="medals"></div>
  </div>

  <!-- JS用 -->
  <script type="application/json" class="js-payload">
  {{ {
    "symbol": sym,
    "score_components": {
      "trends_breakout": trd,
      "news": nws
    }
  } | tojson }}
  </script>

</article>

{% endfor %}
</section>

<footer class="note">
  <h3>How to read</h3>
  <ul>
    <li>Score = Volume + Trends + News</li>
    <li>All normalized to 0–100%</li>
  </ul>
</footer>

</div>

<script>
function decorateTop3Medals(){
  const cards=[...document.querySelectorAll(".card")].map(card=>{
    let data={};
    try{data=JSON.parse(card.querySelector(".js-payload")?.textContent||"{}")}catch{}
    const c=data.score_components||{}
    return {
      card,
      symbol:data.symbol,
      trends:Number(c.trends_breakout||0),
      news:Number(c.news||0)
    }
  })

  const rank=(k)=>[...cards]
    .sort((a,b)=>b[k]-a[k])
    .slice(0,3)

  const t=rank("trends")
  const n=rank("news")

  const medal=(i)=>["🥇","🥈","🥉"][i]

  t.forEach((x,i)=>{
    const el=document.createElement("span")
    el.textContent=`${medal(i)} Trends`
    x.card.querySelector(".medals").appendChild(el)
  })

  n.forEach((x,i)=>{
    const el=document.createElement("span")
    el.textContent=`${medal(i)} News`
    x.card.querySelector(".medals").appendChild(el)
  })
}
document.addEventListener("DOMContentLoaded",decorateTop3Medals)
</script>

</body>
</html>
