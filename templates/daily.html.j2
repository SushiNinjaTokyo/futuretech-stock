<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock — Daily Top 10 ({{ date }})</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/daily.css">
</head>

<body>
<div class="page-shell">
  <div class="ambient ambient-a"></div>
  <div class="ambient ambient-b"></div>
  <div class="grid-overlay"></div>

  <main class="wrap">
    <header class="hero hero-terminal">
      <div class="hero-noise"></div>
      <div class="hero-scan"></div>

      <div class="hero-copy">
        <div class="hero-kicker">MARKET SIGNALS</div>

        <h1 class="hero-title">
          <span class="glitch-title" data-text="Top 10 Movers">Top 10 Movers</span>
        </h1>

        <p class="hero-sub">
          Breakout candidates ranked by volume, structure, and momentum.
        </p>

        <div class="hero-meta-inline">
          <span class="hero-date-label">Market date</span>
          <span class="hero-date-value">{{ date }}</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-visual-head">
          <div class="pulse-dot"></div>
          <span>Market Pulse</span>
        </div>

        <div class="hero-lines">
          {% for key in ['sp500', 'nasdaq', 'russell'] %}
            {% set row = hero_index_lines[key] | default({}, true) %}
            <div class="hero-line-row" data-line-key="{{ key }}">
              <div class="hero-line-meta">
                <div class="hero-line-label">{{ row.label | default(key|upper, true) }}</div>
                <div class="hero-line-change {% if row.change_1m is not none and row.change_1m > 0 %}up{% elif row.change_1m is not none and row.change_1m < 0 %}down{% else %}flat{% endif %}">
                  {% if row.change_1m is not none %}
                    {% if row.change_1m > 0 %}+{% endif %}{{ row.change_1m | round(2) }}%
                  {% else %}
                    —
                  {% endif %}
                </div>
              </div>

              <div class="hero-line-canvas-wrap">
                <svg class="hero-line-svg {{ key }}" viewBox="0 0 520 120" preserveAspectRatio="none" aria-hidden="true">
                  <defs>
                    <linearGradient id="hero-grad-{{ key }}" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="rgba(255,255,255,0)"/>
                      <stop offset="18%" stop-color="var(--hero-line-mid, rgba(255,255,255,.28))"/>
                      <stop offset="70%" stop-color="var(--hero-line-end, rgba(255,255,255,1))"/>
                      <stop offset="100%" stop-color="var(--hero-line-end, rgba(255,255,255,1))"/>
                    </linearGradient>
                    <filter id="hero-glow-{{ key }}" x="-30%" y="-100%" width="160%" height="300%">
                      <feGaussianBlur stdDeviation="3.5" result="blur"/>
                      <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                      </feMerge>
                    </filter>
                  </defs>

                  <path class="hero-line-track" d="" />
                  <path class="hero-line-core" d="" />
                </svg>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      <script type="application/json" id="hero-index-data">
      {{ hero_index_lines | tojson }}
      </script>
    </header>

    {% macro signal_tier(v) -%}
      {%- if v >= 0.90 -%}Elite
      {%- elif v >= 0.75 -%}Strong
      {%- elif v >= 0.55 -%}Good
      {%- elif v >= 0.35 -%}Watch
      {%- else -%}Weak
      {%- endif -%}
    {%- endmacro %}

    {% macro signal_tone(v) -%}
      {%- if v >= 0.90 -%}elite
      {%- elif v >= 0.75 -%}strong
      {%- elif v >= 0.55 -%}good
      {%- elif v >= 0.35 -%}watch
      {%- else -%}weak
      {%- endif -%}
    {%- endmacro %}

    <section class="cards">
      {% for item in (top10 or []) %}
      {% set sym = item.symbol | default('', true) %}
      {% set nm = item.name | default('', true) %}
      {% set rk = loop.index %}
      {% set d1 = item.price_delta_1d %}
      {% set d5 = item.price_delta_1w %}
      {% set d20 = item.price_delta_1m %}
      {% set score_pts = item.score_pts | default(0, true) %}
      {% set score01 = item.final_score_0_1 | default(0, true) %}
      {% set score100 = (score01 * 100) | round(1) %}
      {% set chart_url = item.chart_url | default('', true) %}
      {% set comps = item.score_components | default({}, true) %}
      {% set detail = item.detail | default({}, true) %}
      {% set badges = detail.chart_badges | default({}, true) %}
      {% set rs = detail.relative_strength | default({}, true) %}
      {% set vol = comps.volume_anomaly | default(0, true) %}
      {% set comp = comps.compression_release | default(0, true) %}
      {% set trends = comps.trends_breakout | default(0, true) %}
      {% set news = comps.news | default(0, true) %}

      {% set close_pos = badges.close_pos | default({}, true) %}
      {% set rvol = badges.rvol | default({}, true) %}
      {% set thrust = badges.thrust | default({}, true) %}
      {% set vol_setup = badges.vol_setup | default({}, true) %}

      <article class="stock-card rank-{{ rk }}" data-symbol="{{ sym }}">
        <div class="card-topline"></div>

        <div class="card-head">
          <div class="identity-zone">
            {% if rk <= 3 %}
            <div class="rank-orb rank{{ rk }}" aria-label="Rank {{ rk }}">
              <span class="orb-rank">#{{ rk }}</span>
              <span class="orb-rocket">🚀</span>
            </div>
            {% else %}
            <div class="rank-pill">#{{ rk }}</div>
            {% endif %}

            <div class="identity-copy">
              <div class="symbol-row">
                <span class="symbol">{{ sym }}</span>
                <span class="company">{{ nm }}</span>
              </div>
              <div class="microline">Signal blend • Daily momentum view</div>
            </div>
          </div>

          <div class="score-stack">
            <div class="score-ring" style="--score: {{ score100 }};">
              <div class="score-ring-inner">
                <div class="score-number">{{ score_pts }}</div>
                <div class="score-label">pts</div>
              </div>
            </div>
            <div class="score-mini">{{ score100 }} / 100</div>
          </div>
        </div>

        <div class="price-strip">
          {% macro chip(v, label) -%}
            {% if v is none %}
              <div class="metric-chip neutral">
                <span class="metric-k">{{ label }}</span>
                <span class="metric-v">—</span>
              </div>
            {% else %}
              {% set cls = 'up' if v > 0 else ('down' if v < 0 else 'neutral') %}
              <div class="metric-chip {{ cls }}">
                <span class="metric-k">{{ label }}</span>
                <span class="metric-v">
                  {% if v > 0 %}+{% endif %}{{ v | round(2) }}%
                </span>
              </div>
            {% endif %}
          {%- endmacro %}

          {{ chip(d1, "1D") }}
          {{ chip(d5, "1W") }}
          {{ chip(d20, "1M") }}
        </div>

        <div class="signal-panel">
          <div class="signal-head">
            <div class="signal-title">Signal Breakdown</div>
            <div class="medals"></div>
          </div>

          <div class="signal-grid">
            <div class="signal-row">
              <div class="signal-label">Volume</div>
              <div class="signal-bar"><i style="width: {{ (vol * 100) | round(1) }}%"></i></div>
              <div class="signal-tag {{ signal_tone(vol) }}">{{ signal_tier(vol) }} · {{ (vol * 100) | round(0) }}</div>
            </div>

            <div class="signal-row">
              <div class="signal-label">Compression</div>
              <div class="signal-bar"><i style="width: {{ (comp * 100) | round(1) }}%"></i></div>
              <div class="signal-tag {{ signal_tone(comp) }}">{{ signal_tier(comp) }} · {{ (comp * 100) | round(0) }}</div>
            </div>

            <div class="signal-row">
              <div class="signal-label">Trends</div>
              <div class="signal-bar"><i style="width: {{ (trends * 100) | round(1) }}%"></i></div>
              <div class="signal-tag {{ signal_tone(trends) }}">{{ signal_tier(trends) }} · {{ (trends * 100) | round(0) }}</div>
            </div>

            <div class="signal-row">
              <div class="signal-label">News</div>
              <div class="signal-bar"><i style="width: {{ (news * 100) | round(1) }}%"></i></div>
              <div class="signal-tag {{ signal_tone(news) }}">{{ signal_tier(news) }} · {{ (news * 100) | round(0) }}</div>
            </div>
          </div>
        </div>

        <div class="badge-panel">
          <div class="badge-title">Chart Signals</div>
          <div class="badge-grid">
            <div class="chart-badge {{ close_pos.tone | default('hold', true) }}">
              <div class="badge-k">Close Pos</div>
              <div class="badge-main">{{ close_pos.label | default('N/A', true) }}</div>
              <div class="badge-v">{{ close_pos.display | default('N/A', true) }}</div>
            </div>

            <div class="chart-badge {{ rvol.tone | default('hold', true) }}">
              <div class="badge-k">RVOL</div>
              <div class="badge-main">{{ rvol.label | default('N/A', true) }}</div>
              <div class="badge-v">{{ rvol.display | default('N/A', true) }}</div>
            </div>

            <div class="chart-badge {{ thrust.tone | default('hold', true) }}">
              <div class="badge-k">Thrust</div>
              <div class="badge-main">{{ thrust.label | default('N/A', true) }}</div>
              <div class="badge-v">{{ thrust.display | default('N/A', true) }}</div>
            </div>

            <div class="chart-badge {{ vol_setup.tone | default('flat', true) }}">
              <div class="badge-k">Vol Setup</div>
              <div class="badge-main">{{ vol_setup.label | default('N/A', true) }}</div>
              <div class="badge-v">{{ vol_setup.display | default('N/A', true) }}</div>
            </div>
          </div>
        </div>

        <div class="relative-panel">
          <div class="relative-title">Relative Strength</div>
          <div class="relative-list">
            {% for key in ['sp500', 'nasdaq', 'russell'] %}
              {% set row = rs[key] | default({}, true) %}
              {% set price = row.price | default({}, true) %}
              {% set vacc = row.vol_accel | default({}, true) %}
              <div class="relative-row">
                <div class="relative-index">vs {{ row.name | default(key, true) }}</div>
                <div class="relative-badges">
                  <div class="relative-badge {{ price.tone | default('neutral', true) }}">
                    <span class="relative-type">Price</span>
                    <span class="relative-value">{{ price.display | default('N/A', true) }}</span>
                    <span class="relative-label">{{ price.label | default('N/A', true) }}</span>
                  </div>
                  <div class="relative-badge vol {{ vacc.tone | default('neutral', true) }}">
                    <span class="relative-type">VolAccel</span>
                    <span class="relative-value">{{ vacc.display | default('N/A', true) }}</span>
                    <span class="relative-label">{{ vacc.label | default('N/A', true) }}</span>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        {% if chart_url %}
        <div class="chart-panel">
          <div class="chart-head">
            <span>Daily Chart · 3M</span>
            <span class="chart-symbol">{{ sym }}</span>
          </div>
          <img class="chart" src="{{ chart_url }}" alt="{{ sym }} daily chart" loading="lazy">
        </div>
        {% endif %}

        <script type="application/json" class="js-payload">
        {{ {
          "symbol": sym,
          "score_components": {
            "volume_anomaly": vol,
            "compression_release": comp,
            "trends_breakout": trends,
            "news": news
          }
        } | tojson }}
        </script>
      </article>
      {% endfor %}
    </section>

    <footer class="footer-note">
      <div class="footer-title">Method</div>
      <p>
        This dashboard blends normalized signal components without changing the underlying source data.
        It is informational only and not investment advice.
      </p>
    </footer>
  </main>
</div>

<script>
function decorateTop3Medals(){
  const cards = [...document.querySelectorAll(".stock-card")].map(card => {
    let data = {};
    try {
      data = JSON.parse(card.querySelector(".js-payload")?.textContent || "{}");
    } catch (_) {}

    const comps = data.score_components || {};
    return {
      card,
      symbol: data.symbol || "",
      trends: Number(comps.trends_breakout || 0),
      news: Number(comps.news || 0),
      volume: Number(comps.volume_anomaly || 0)
    };
  });

  const rankBy = (arr, key) =>
    [...arr]
      .sort((a, b) => Number(b[key]) - Number(a[key]))
      .map((o, i) => ({ ...o, _rank: i + 1 }))
      .filter(o => o[key] > 0 && o._rank <= 3);

  const tMap = new Map(rankBy(cards, "trends").map(o => [o.symbol, o._rank]));
  const nMap = new Map(rankBy(cards, "news").map(o => [o.symbol, o._rank]));
  const vMap = new Map(rankBy(cards, "volume").map(o => [o.symbol, o._rank]));

  const medalInfo = r =>
    r === 1 ? ["gold", "🥇"] :
    r === 2 ? ["silver", "🥈"] :
              ["bronze", "🥉"];

  cards.forEach(({ card, symbol }) => {
    const box = card.querySelector(".medals");
    if (!box) return;
    box.innerHTML = "";

    const addMedal = (rank, label) => {
      if (!rank) return;
      const [cls, emoji] = medalInfo(rank);
      const el = document.createElement("span");
      el.className = `medal ${cls}`;
      el.innerHTML = `<span class="emoji">${emoji}</span><span class="kind">${label}</span>`;
      box.appendChild(el);
    };

    addMedal(vMap.get(symbol), "Volume");
    addMedal(tMap.get(symbol), "Trends");
    addMedal(nMap.get(symbol), "News");
  });
}

function buildHeroPath(points, width = 520, height = 120){
  if (!Array.isArray(points) || points.length < 2){
    return "";
  }

  const maxIndex = points.length - 1;
  const coords = points.map((p, i) => {
    const x = (i / maxIndex) * width;
    const y = height - (Math.max(0, Math.min(100, Number(p))) / 100) * (height - 12) - 6;
    return [x, y];
  });

  let d = `M ${coords[0][0].toFixed(2)} ${coords[0][1].toFixed(2)}`;
  for (let i = 1; i < coords.length; i++) {
    const prev = coords[i - 1];
    const curr = coords[i];
    const cx1 = (prev[0] + curr[0]) / 2;
    const cy1 = prev[1];
    const cx2 = (prev[0] + curr[0]) / 2;
    const cy2 = curr[1];
    d += ` C ${cx1.toFixed(2)} ${cy1.toFixed(2)}, ${cx2.toFixed(2)} ${cy2.toFixed(2)}, ${curr[0].toFixed(2)} ${curr[1].toFixed(2)}`;
  }
  return d;
}

function initHeroIndexLines(){
  const el = document.getElementById("hero-index-data");
  if (!el) return;

  let data = {};
  try {
    data = JSON.parse(el.textContent || "{}");
  } catch (_) {
    return;
  }

  document.querySelectorAll(".hero-line-row").forEach((row) => {
    const key = row.getAttribute("data-line-key");
    const series = data[key] || {};
    const points = Array.isArray(series.points) ? series.points : [];
    const svg = row.querySelector(".hero-line-svg");
    const track = row.querySelector(".hero-line-track");
    const core = row.querySelector(".hero-line-core");
    if (!svg || !track || !core || points.length < 2) return;

    const d = buildHeroPath(points, 520, 120);
    track.setAttribute("d", d);
    core.setAttribute("d", d);

    const len = core.getTotalLength();
    track.style.setProperty("--hero-line-length", `${len}`);
    core.style.setProperty("--hero-line-length", `${len}`);
  });
}

document.addEventListener("DOMContentLoaded", () => {
  decorateTop3Medals();
  initHeroIndexLines();
});
</script>
</body>
</html>
