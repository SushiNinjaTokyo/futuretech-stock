<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock — Daily Top 10 ({{ date }})</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>

  <!-- 外部CSS -->
  <link rel="stylesheet" href="/assets/daily.css">
</head>

<body>
<div class="wrap">

  <header>
    <h1>Daily Top 10</h1>
    <div class="sub">Date: {{ date }}</div>
  </header>

  <section class="grid">

    {% for item in (top10 or []) %}
    {% set _sym = item.symbol | default('', true) %}
    {% set _nm  = item.name   | default('', true) %}
    {% set _rk  = loop.index %}
    
    {% set d1  = item.price_delta_1d %}
    {% set d5  = item.price_delta_1w %}
    {% set d20 = item.price_delta_1m %}

    <article class="card">

      <!-- 上段 -->
      <div class="row">
        <div class="left">

          <!-- Rank -->
          {% if _rk <= 3 %}
          <div class="rank-rocket rank{{ _rk }}">
            <span class="rocket">🚀</span>
          </div>
          {% else %}
          <div class="rank-badge">#{{ _rk }}</div>
          {% endif %}

          <!-- 銘柄 -->
          <div class="id-block">
            <div class="symbol">{{ _sym }}</div>
            <div class="name">{{ _nm }}</div>
          </div>
        </div>

        <!-- スコア -->
        <div class="score">
          <div class="num">{{ item.score_pts | default(0) }}</div>
          <div class="den">pts</div>
        </div>
      </div>

      <!-- 価格 -->
      <div class="price-row">

        {% macro chip(v, label) -%}
          {% if v is none %}
            <div class="pch neutral"><span class="k">{{ label }}</span> —</div>
          {% else %}
            {% set cls = 'up' if v > 0 else ('down' if v < 0 else 'neutral') %}
            <div class="pch {{ cls }}">
              <span class="k">{{ label }}</span>
              <span class="delta">{{ v | round(2) }}%</span>
            </div>
          {% endif %}
        {%- endmacro %}

        {{ chip(d1, "1D") }}
        {{ chip(d5, "1W") }}
        {{ chip(d20, "1M") }}

      </div>

      <!-- medals -->
      <div class="medals"></div>

      <!-- JS用データ -->
      <script type="application/json" class="js-payload">
      {{ {
        "symbol": _sym,
        "score_components": item.score_components | default({})
      } | tojson }}
      </script>

    </article>
    {% endfor %}

  </section>

  <div class="note">
    This page is informational and not investment advice.
  </div>

</div>

<script>
function decorateTop3Medals(){
  const cards = [...document.querySelectorAll(".card")].map(card=>{
    let data = {};
    try {
      data = JSON.parse(card.querySelector(".js-payload")?.textContent || "{}");
    } catch(_) {}

    const comps = data.score_components || {};

    return {
      card,
      symbol: data.symbol,
      trends: Number(comps.trends_breakout || 0),
      news:   Number(comps.news || 0)
    };
  });

  const rankBy = (arr, key) =>
    [...arr].sort((a,b)=>b[key]-a[key])
            .map((o,i)=>({...o,_rank:i+1}))
            .filter(o=>o[key]>0 && o._rank<=3);

  const tMap = new Map(rankBy(cards,"trends").map(o=>[o.symbol,o._rank]));
  const nMap = new Map(rankBy(cards,"news").map(o=>[o.symbol,o._rank]));

  const medalInfo = r => r===1?["gold","🥇"]:r===2?["silver","🥈"]:["bronze","🥉"];

  cards.forEach(({card,symbol})=>{
    const box = card.querySelector(".medals");
    if(!box) return;

    box.innerHTML = "";

    const t = tMap.get(symbol);
    if(t){
      const [cls,emoji] = medalInfo(t);
      box.innerHTML += `<span class="medal ${cls}"><span class="emoji">${emoji}</span><span class="kind">Trends</span></span>`;
    }

    const n = nMap.get(symbol);
    if(n){
      const [cls,emoji] = medalInfo(n);
      box.innerHTML += `<span class="medal ${cls}"><span class="emoji">${emoji}</span><span class="kind">News</span></span>`;
    }
  });
}

document.addEventListener("DOMContentLoaded", decorateTop3Medals);
</script>

</body>
</html>
