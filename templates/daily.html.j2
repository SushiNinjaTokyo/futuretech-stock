<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock — Daily Signals</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/daily.css">
</head>
<body>
<div class="page">
  <div class="ambient a"></div><div class="ambient b"></div><div class="grid"></div>
  <main class="wrap">
    {% macro money(v) -%}{% if v is none %}—{% else %}${{ "{:,.0f}".format(v|float) }}{% endif %}{%- endmacro %}
    {% macro pct(v) -%}{% if v is none %}—{% else %}{% if v > 0 %}+{% endif %}{{ "{:.2f}".format(v|float) }}%{% endif %}{%- endmacro %}
    {% macro score(v) -%}{% if v is none %}—{% else %}{{ v }}{% endif %}{%- endmacro %}
    {% macro tone(v) -%}{% if v is none %}neutral{% elif v > 0 %}up{% elif v < 0 %}down{% else %}neutral{% endif %}{%- endmacro %}
    {% macro comp_bar(label, val, max=1) -%}
      {% set p = 0 if val is none else ([100, [0, (val|float / max * 100)]|max]|min) %}
      <div class="comp"><span>{{ label }}</span><b>{{ "{:.0f}".format(p) }}%</b><i><em style="width:{{ p }}%"></em></i></div>
    {%- endmacro %}

    <header class="hero">
      <div>
        <a class="back" href="/">← Home</a>
        <div class="kicker">Daily Event Signal Lab</div>
        <h1>Top 10 Movers</h1>
        <p>Breakout timing candidates ranked by volume shock, compression release, setup quality, relative strength, and entry-risk controls.</p>
        <div class="chips">
          <span>Market date {{ date }}</span>
          <span>Trade {{ summary.trade | default(0) }}</span>
          <span>Watch {{ summary.watch | default(0) }}</span>
          <span>Scored {{ summary.scored | default(0) }}</span>
        </div>
      </div>
      <aside class="market-card">
        <div class="card-label">Market Regime</div>
        <div class="market-grid">
          {% for key,row in market.items() %}
          <div><span>{{ row.symbol | default(key|upper) }}</span><strong>{{ row.regime | default('—') }}</strong><small>{{ pct(row.ret_5d_pct) }} 5D</small></div>
          {% endfor %}
        </div>
      </aside>
    </header>

    <section class="kpis">
      <article><span>Trade</span><strong>{{ summary.trade | default(0) }}</strong><small>high-quality timing</small></article>
      <article><span>Watch</span><strong>{{ summary.watch | default(0) }}</strong><small>needs confirmation</small></article>
      <article><span>Ignore</span><strong>{{ summary.ignore | default(0) }}</strong><small>penalized / weak timing</small></article>
      <article><span>Scored Universe</span><strong>{{ summary.scored | default(0) }}</strong><small>failed {{ summary.failed | default(0) }}</small></article>
    </section>

    <section class="cards">
      {% for item in items[:10] %}
      <article class="signal-card {{ item.triage|lower }}">
        <div class="rank">#{{ item.rank }}</div>
        <div class="signal-head">
          <div><h2>{{ item.symbol }}</h2><p>{{ item.name or item.archetype }}</p></div>
          <div class="score {{ item.triage|lower }}">{{ item.score_pts }}</div>
        </div>
        <div class="badges"><span>{{ item.triage }}</span><span>{{ item.archetype }}</span><span>{{ item.regime }}</span></div>
        <p class="reason">{{ item.reason }}</p>
        <div class="metric-row">
          <div><span>Price</span><strong>{{ money(item.price) }}</strong></div>
          <div><span>RVOL</span><strong>{{ item.metrics.rvol20 | default('—') }}x</strong></div>
          <div><span>5D</span><strong class="{{ tone(item.metrics.ret_5d_pct) }}">{{ pct(item.metrics.ret_5d_pct) }}</strong></div>
          <div><span>RS 20D</span><strong class="{{ tone(item.metrics.rs_20d_vs_qqq) }}">{{ pct(item.metrics.rs_20d_vs_qqq) }}</strong></div>
        </div>
        <div class="component-grid">
          {{ comp_bar('Volume', item.v2_components.volume_liquidity_shock) }}
          {{ comp_bar('Compression', item.v2_components.compression_release) }}
          {{ comp_bar('Setup', item.v2_components.breakout_setup_quality) }}
          {{ comp_bar('RS', item.v2_components.relative_strength) }}
          {{ comp_bar('Timing', item.v2_components.entry_timing) }}
          {{ comp_bar('Penalty', item.v2_components.penalty, 0.35) }}
        </div>
      </article>
      {% endfor %}
    </section>

    <footer class="footer">Generated {{ generated_at }} · Data stored separately under daily-v2 while the UI remains the primary daily page.</footer>
  </main>
</div>
</body>
</html>
