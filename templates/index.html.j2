<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock Intelligence</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/index.css?v=20260514-daily-simulation-pulse">
</head>

<body>
<div class="page">
  <div class="ambient ambient-a"></div>
  <div class="ambient ambient-b"></div>
  <div class="ambient ambient-c"></div>
  <div class="grid"></div>

  <main class="wrap">
    <section class="hero">
      <div class="hero-copy">
        <div class="kicker">
          <span class="kicker-dot"></span>
          FutureTech Stock Intelligence
        </div>

        <h1>
          Market first.<br/>
          Signals second.
        </h1>

        <p>
          A focused cockpit for finding early, tradable momentum in future technology stocks.
          Market context comes first; individual signals only matter when timing, volume,
          setup quality, relative strength, and risk-reward align.
        </p>

        <div class="hero-actions">
          <a class="hero-button primary" href="/daily/">Open Daily Top 10</a>
          <a class="hero-button" href="/daily-simulation/">View Daily Simulation</a>
        </div>
      </div>

      <div class="regime-card {{ market.regime_tone | default('neutral', true) }}">
        <div class="regime-orbit">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="regime-label">Market Regime</div>
        <div class="regime-value">{{ market.regime | default('Unknown', true) }}</div>
        <div class="regime-date">As of {{ market.date }}</div>

        <div class="regime-pulse">
          <div class="pulse-bar"></div>
        </div>
      </div>
    </section>

    <section class="market-panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Market Pulse</div>
          <h2>Index Performance</h2>
          <p>
            Normalized momentum paths for the major risk proxies. The line is not just decoration:
            it shows where each index sits within its recent market rhythm.
          </p>
        </div>

        <div class="pulse-legend">
          <span class="legend-chip">Spark path</span>
          <span class="legend-chip">20D trend</span>
          <span class="legend-chip">Risk state</span>
        </div>
      </div>

      <div class="market-stage">
        <div class="stage-scan"></div>
        <div class="stage-lightning"></div>

        <div class="index-grid">
          {% for row in indices %}
          <article class="index-card {{ row.tone | default('', true) }}">
            <div class="index-glow"></div>

            <div class="index-top">
              <div>
                <div class="index-label">{{ row.label }}</div>
                <div class="index-symbol">{{ row.symbol }}</div>
              </div>

              <div class="index-status {% if row.above_20dma %}up{% elif row.above_20dma is not none %}down{% else %}flat{% endif %}">
                {% if row.above_20dma is none %}
                  N/A
                {% elif row.above_20dma %}
                  Above 20D
                {% else %}
                  Below 20D
                {% endif %}
              </div>
            </div>

            <div class="spark-wrap">
              <div class="spark-scan"></div>

              <svg class="spark"
                   viewBox="0 0 520 140"
                   preserveAspectRatio="none"
                   data-points="{{ row.points | join(',') }}">
                <defs>
                  <linearGradient id="sparkGradient{{ loop.index }}" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="rgba(125, 249, 255, 0.10)"></stop>
                    <stop offset="45%" stop-color="rgba(125, 249, 255, 0.85)"></stop>
                    <stop offset="100%" stop-color="rgba(183, 121, 255, 0.95)"></stop>
                  </linearGradient>
                </defs>

                <path class="spark-track" d=""></path>
                <path class="spark-line" d="" stroke="url(#sparkGradient{{ loop.index }})"></path>
                <path class="spark-bolt" d=""></path>
                <circle class="spark-dot" cx="0" cy="0" r="4"></circle>
              </svg>
            </div>

            <div class="perf-row">
              {% for key, label in [('return_1d','1D'), ('return_5d','5D'), ('return_20d','20D')] %}
                {% set v = row[key] %}
                <div class="perf-chip {% if v is not none and v > 0 %}up{% elif v is not none and v < 0 %}down{% else %}flat{% endif %}">
                  <span>{{ label }}</span>
                  <strong>
                    {% if v is none %}
                      —
                    {% else %}
                      {% if v > 0 %}+{% endif %}{{ v | round(2) }}%
                    {% endif %}
                  </strong>
                </div>
              {% endfor %}
            </div>
          </article>
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="nav-grid">
      <a class="nav-card primary" href="/daily/">
        <div class="nav-kicker">Today</div>
        <h3>Daily Top 10</h3>
        <p>
          Open the latest ranked setups built around timing, volume expansion,
          compression release, relative strength, and entry-risk discipline.
        </p>
        <div class="nav-meta">
          {% if top10.top_symbol %}
            #1 {{ top10.top_symbol }}
            {% if top10.top_score is not none %}
              / {{ top10.top_score | round(0) | int }} pts
            {% endif %}
            · {{ top10.top_classification | default('Latest ranking', true) }}
          {% else %}
            Latest ranking
          {% endif %}
        </div>
      </a>

      <a class="nav-card" href="/backtest/">
        <div class="nav-kicker">Daily Validation</div>
        <h3>Daily Backtest</h3>
        <p>
          Measure whether daily signals actually follow through after entry,
          including short-horizon returns, alpha, stop behavior, and signal archetypes.
        </p>
        <div class="nav-meta">Event Signal Lab</div>
      </a>

      <a class="nav-card accent" href="/daily-simulation/">
        <div class="nav-kicker">Daily Portfolio Simulation</div>
        <h3>Daily Simulation</h3>
        <p>
          Simulate Daily signals as a real capital process with compounding,
          exit rules, QQQ/SPY benchmark comparison, drawdown, and open-position exposure.
        </p>
        <div class="nav-meta">Compounding / QQQ Alpha / Exit Rules</div>
      </a>

      <a class="nav-card" href="/weekly/">
        <div class="nav-kicker">Medium-Term Screening</div>
        <h3>Weekly Screening</h3>
        <p>
          Review weekly candidates based on trend quality, relative strength,
          breakout freshness, setup quality, and accumulation.
        </p>
        <div class="nav-meta">Stage 2 / RS / Breakout / VCP</div>
      </a>

      <a class="nav-card" href="/weekly-backtest/">
        <div class="nav-kicker">Weekly Validation</div>
        <h3>Weekly Backtest</h3>
        <p>
          Validate B-or-better weekly signals from Saturday snapshots using next-open entries
          and 1W, 2W, 4W, and 8W performance windows.
        </p>
        <div class="nav-meta">B+ Weekly Signal Tracker</div>
      </a>

      <a class="nav-card" href="/weekly-simulation/">
        <div class="nav-kicker">Portfolio Simulation</div>
        <h3>Weekly Simulation</h3>
        <p>
          Simulate add-on and reinvestment behavior to understand whether signal quality
          survives portfolio-level execution.
        </p>
        <div class="nav-meta">Capital / Alpha / Drawdown</div>
      </a>
    </section>

    <footer class="footer">
      Generated at {{ generated_at }} · Informational only, not investment advice.
    </footer>
  </main>
</div>

<script>
function buildPath(points, width = 520, height = 140){
  if (!points || points.length < 2) return "";

  const coords = points.map((p, i) => {
    const x = (i / (points.length - 1)) * width;
    const y = height - (Math.max(0, Math.min(100, Number(p))) / 100) * (height - 18) - 9;
    return [x, y];
  });

  let d = `M ${coords[0][0].toFixed(2)} ${coords[0][1].toFixed(2)}`;

  for (let i = 1; i < coords.length; i++) {
    const prev = coords[i - 1];
    const curr = coords[i];
    const cx1 = (prev[0] + curr[0]) / 2;
    const cx2 = (prev[0] + curr[0]) / 2;
    d += ` C ${cx1.toFixed(2)} ${prev[1].toFixed(2)}, ${cx2.toFixed(2)} ${curr[1].toFixed(2)}, ${curr[0].toFixed(2)} ${curr[1].toFixed(2)}`;
  }

  return d;
}

function buildBoltPath(points, width = 520, height = 140){
  if (!points || points.length < 2) return "";

  const step = width / (points.length - 1);
  let d = "";

  points.forEach((p, i) => {
    const x = i * step;
    const baseY = height - (Math.max(0, Math.min(100, Number(p))) / 100) * (height - 18) - 9;
    const y = baseY + (i % 2 === 0 ? -2 : 2);
    d += i === 0 ? `M ${x.toFixed(2)} ${y.toFixed(2)}` : ` L ${x.toFixed(2)} ${y.toFixed(2)}`;
  });

  return d;
}

document.querySelectorAll(".spark").forEach(svg => {
  const raw = svg.getAttribute("data-points") || "";
  const points = raw.split(",").map(Number).filter(v => Number.isFinite(v));

  const smoothPath = buildPath(points);
  const boltPath = buildBoltPath(points);

  const track = svg.querySelector(".spark-track");
  const line = svg.querySelector(".spark-line");
  const bolt = svg.querySelector(".spark-bolt");
  const dot = svg.querySelector(".spark-dot");

  if (track) track.setAttribute("d", smoothPath);
  if (line) line.setAttribute("d", smoothPath);
  if (bolt) bolt.setAttribute("d", boltPath);

  if (dot && points.length >= 2) {
    const last = points[points.length - 1];
    const x = 520;
    const y = 140 - (Math.max(0, Math.min(100, Number(last))) / 100) * (140 - 18) - 9;
    dot.setAttribute("cx", x.toFixed(2));
    dot.setAttribute("cy", y.toFixed(2));
  }
});
</script>
</body>
</html>
