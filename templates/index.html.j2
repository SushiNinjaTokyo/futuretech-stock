<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock Intelligence</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/index.css?v=20260514-market-pulse-stage">
</head>

<body>
<div class="page">
  <div class="ambient ambient-a"></div>
  <div class="ambient ambient-b"></div>
  <div class="ambient ambient-c"></div>
  <div class="grid"></div>

  <main class="wrap">
    <section class="hero">
      <div class="hero-copy">
        <div class="kicker">
          <span class="kicker-dot"></span>
          FutureTech Stock Intelligence
        </div>

        <h1>
          Market first.<br/>
          Signals second.
        </h1>

        <p>
          A focused cockpit for finding early, tradable momentum in future technology stocks.
          Market context comes first; individual signals only matter when timing, volume,
          setup quality, relative strength, and risk-reward align.
        </p>

        <div class="hero-actions">
          <a class="hero-button primary" href="/daily/">Open Daily Top 10</a>
          <a class="hero-button" href="/daily-simulation/">View Daily Simulation</a>
        </div>
      </div>

      <div class="regime-card {{ market.regime_tone | default('neutral', true) }}">
        <div class="regime-orbit">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="regime-label">Market Regime</div>
        <div class="regime-value">{{ market.regime | default('Unknown', true) }}</div>
        <div class="regime-date">As of {{ market.date }}</div>

        <div class="regime-pulse">
          <div class="pulse-bar"></div>
        </div>
      </div>
    </section>

    <section class="market-panel cinematic">
      <div class="section-head">
        <div>
          <div class="section-kicker">Market Pulse</div>
          <h2>Risk Current</h2>
          <p>
            A rotating pulse of the major risk proxies. Each bolt follows the actual normalized
            recent price path, turning market context into a single visual signal.
          </p>
        </div>
      </div>

      <div class="pulse-stage" id="pulseStage">
        <div class="pulse-bg-grid"></div>
        <div class="pulse-bg-word" id="pulseBgWord">S&amp;P 500</div>
        <div class="pulse-scan"></div>
        <div class="pulse-flash"></div>

        <div class="pulse-topline">
          <div>
            <div class="pulse-label">Now tracking</div>
            <div class="pulse-name" id="pulseName">S&amp;P 500</div>
          </div>
          <div class="pulse-symbol" id="pulseSymbol">SPY</div>
        </div>

        <div class="pulse-chart-wrap">
          <svg class="pulse-chart" viewBox="0 0 1000 360" preserveAspectRatio="none">
            {% for row in indices %}
            <path
              class="pulse-path pulse-path-{{ loop.index0 }}"
              data-index="{{ loop.index0 }}"
              data-label="{{ row.label }}"
              data-symbol="{{ row.symbol }}"
              data-tone="{{ row.tone | default('', true) }}"
              data-ret1d="{% if row.return_1d is not none %}{{ row.return_1d | round(2) }}{% endif %}"
              data-ret5d="{% if row.return_5d is not none %}{{ row.return_5d | round(2) }}{% endif %}"
              data-ret20d="{% if row.return_20d is not none %}{{ row.return_20d | round(2) }}{% endif %}"
              data-points="{{ row.points | join(',') }}"
              d="">
            </path>
            {% endfor %}

            <path class="pulse-trace" d=""></path>
            <path class="pulse-bolt" d=""></path>
            <circle class="pulse-head" cx="0" cy="0" r="7"></circle>
          </svg>
        </div>

        <div class="pulse-bottom">
          <div class="pulse-metric">
            <span>1D</span>
            <strong id="pulseRet1d">—</strong>
          </div>
          <div class="pulse-metric">
            <span>5D</span>
            <strong id="pulseRet5d">—</strong>
          </div>
          <div class="pulse-metric">
            <span>20D</span>
            <strong id="pulseRet20d">—</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="nav-grid">
      <a class="nav-card primary" href="/daily/">
        <div class="nav-kicker">Today</div>
        <h3>Daily Top 10</h3>
        <p>
          Open the latest ranked setups built around timing, volume expansion,
          compression release, relative strength, and entry-risk discipline.
        </p>
        <div class="nav-meta">
          {% if top10.top_symbol %}
            #1 {{ top10.top_symbol }}
            {% if top10.top_score is not none %}
              / {{ top10.top_score | round(0) | int }} pts
            {% endif %}
            · {{ top10.top_classification | default('Latest ranking', true) }}
          {% else %}
            Latest ranking
          {% endif %}
        </div>
      </a>

      <a class="nav-card" href="/backtest/">
        <div class="nav-kicker">Daily Validation</div>
        <h3>Daily Backtest</h3>
        <p>
          Measure whether daily signals actually follow through after entry,
          including short-horizon returns, alpha, stop behavior, and signal archetypes.
        </p>
        <div class="nav-meta">Event Signal Lab</div>
      </a>

      <a class="nav-card accent" href="/daily-simulation/">
        <div class="nav-kicker">Daily Portfolio Simulation</div>
        <h3>Daily Simulation</h3>
        <p>
          Simulate Daily signals as a real capital process with compounding,
          exit rules, QQQ/SPY benchmark comparison, drawdown, and open-position exposure.
        </p>
        <div class="nav-meta">Compounding / QQQ Alpha / Exit Rules</div>
      </a>

      <a class="nav-card" href="/weekly/">
        <div class="nav-kicker">Medium-Term Screening</div>
        <h3>Weekly Screening</h3>
        <p>
          Review weekly candidates based on trend quality, relative strength,
          breakout freshness, setup quality, and accumulation.
        </p>
        <div class="nav-meta">Stage 2 / RS / Breakout / VCP</div>
      </a>

      <a class="nav-card" href="/weekly-backtest/">
        <div class="nav-kicker">Weekly Validation</div>
        <h3>Weekly Backtest</h3>
        <p>
          Validate B-or-better weekly signals from Saturday snapshots using next-open entries
          and 1W, 2W, 4W, and 8W performance windows.
        </p>
        <div class="nav-meta">B+ Weekly Signal Tracker</div>
      </a>

      <a class="nav-card" href="/weekly-simulation/">
        <div class="nav-kicker">Portfolio Simulation</div>
        <h3>Weekly Simulation</h3>
        <p>
          Simulate add-on and reinvestment behavior to understand whether signal quality
          survives portfolio-level execution.
        </p>
        <div class="nav-meta">Capital / Alpha / Drawdown</div>
      </a>
    </section>

    <footer class="footer">
      Generated at {{ generated_at }} · Informational only, not investment advice.
    </footer>
  </main>
</div>

<script>
function pathFromPoints(points, width = 1000, height = 360) {
  if (!points || points.length < 2) return "";

  const coords = points.map((p, i) => {
    const x = (i / (points.length - 1)) * width;
    const y = height - (Math.max(0, Math.min(100, Number(p))) / 100) * (height - 44) - 22;
    return [x, y];
  });

  let d = `M ${coords[0][0].toFixed(2)} ${coords[0][1].toFixed(2)}`;

  for (let i = 1; i < coords.length; i++) {
    const prev = coords[i - 1];
    const curr = coords[i];
    const cx1 = (prev[0] + curr[0]) / 2;
    const cx2 = (prev[0] + curr[0]) / 2;
    d += ` C ${cx1.toFixed(2)} ${prev[1].toFixed(2)}, ${cx2.toFixed(2)} ${curr[1].toFixed(2)}, ${curr[0].toFixed(2)} ${curr[1].toFixed(2)}`;
  }

  return d;
}

function jaggedPathFromPoints(points, width = 1000, height = 360) {
  if (!points || points.length < 2) return "";

  const step = width / (points.length - 1);
  let d = "";

  points.forEach((p, i) => {
    const x = i * step;
    const baseY = height - (Math.max(0, Math.min(100, Number(p))) / 100) * (height - 44) - 22;
    const y = baseY + (i % 2 === 0 ? -4 : 4);
    d += i === 0 ? `M ${x.toFixed(2)} ${y.toFixed(2)}` : ` L ${x.toFixed(2)} ${y.toFixed(2)}`;
  });

  return d;
}

function formatPct(v) {
  if (v === null || v === undefined || v === "" || !Number.isFinite(Number(v))) return "—";
  const n = Number(v);
  return `${n > 0 ? "+" : ""}${n.toFixed(2)}%`;
}

const stage = document.getElementById("pulseStage");
const bgWord = document.getElementById("pulseBgWord");
const nameEl = document.getElementById("pulseName");
const symbolEl = document.getElementById("pulseSymbol");
const ret1dEl = document.getElementById("pulseRet1d");
const ret5dEl = document.getElementById("pulseRet5d");
const ret20dEl = document.getElementById("pulseRet20d");
const paths = Array.from(document.querySelectorAll(".pulse-path"));
const trace = document.querySelector(".pulse-trace");
const bolt = document.querySelector(".pulse-bolt");
const head = document.querySelector(".pulse-head");

const pulseData = paths.map((path, index) => {
  const raw = path.getAttribute("data-points") || "";
  const points = raw.split(",").map(Number).filter(v => Number.isFinite(v));
  const smooth = pathFromPoints(points);
  const jagged = jaggedPathFromPoints(points);

  path.setAttribute("d", smooth);

  return {
    index,
    path,
    points,
    smooth,
    jagged,
    label: path.getAttribute("data-label") || "Market",
    symbol: path.getAttribute("data-symbol") || "",
    tone: path.getAttribute("data-tone") || "",
    ret1d: path.getAttribute("data-ret1d"),
    ret5d: path.getAttribute("data-ret5d"),
    ret20d: path.getAttribute("data-ret20d")
  };
}).filter(d => d.points.length >= 2);

let activeIndex = 0;

function activatePulse(i) {
  if (!pulseData.length) return;

  const item = pulseData[i % pulseData.length];

  stage.dataset.tone = item.tone || "";
  bgWord.textContent = item.label;
  nameEl.textContent = item.label;
  symbolEl.textContent = item.symbol;
  ret1dEl.textContent = formatPct(item.ret1d);
  ret5dEl.textContent = formatPct(item.ret5d);
  ret20dEl.textContent = formatPct(item.ret20d);

  paths.forEach(p => p.classList.remove("active"));
  item.path.classList.add("active");

  trace.setAttribute("d", item.smooth);
  bolt.setAttribute("d", item.jagged);

  const last = item.points[item.points.length - 1];
  const x = 1000;
  const y = 360 - (Math.max(0, Math.min(100, Number(last))) / 100) * (360 - 44) - 22;
  head.setAttribute("cx", x.toFixed(2));
  head.setAttribute("cy", y.toFixed(2));

  trace.style.animation = "none";
  bolt.style.animation = "none";
  head.style.animation = "none";

  requestAnimationFrame(() => {
    trace.style.animation = "";
    bolt.style.animation = "";
    head.style.animation = "";
  });
}

activatePulse(activeIndex);

setInterval(() => {
  activeIndex = (activeIndex + 1) % Math.max(1, pulseData.length);
  activatePulse(activeIndex);
}, 4200);
</script>
</body>
</html>
