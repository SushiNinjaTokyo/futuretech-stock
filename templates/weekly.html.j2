<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Weekly Minervini Screen | FutureTech Stock Intelligence</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/weekly.css">
</head>
<body>
<div class="page">
  <div class="ambient ambient-a"></div>
  <div class="ambient ambient-b"></div>

  <header class="topbar">
    <a class="brand" href="/">FutureTech Stock Intelligence</a>
    <nav>
      <a href="/">Home</a>
      <a href="/backtest/">Backtest</a>
      <a href="/weekly/" aria-current="page">Weekly</a>
    </nav>
  </header>

  <main class="wrap">
    <section class="hero">
      <div>
        <div class="kicker">Weekly Screening</div>
        <h1>Minervini-style<br/>leader candidates.</h1>
        <p>
          CSV-based weekly ranking focused on Stage 2 trend quality, relative strength,
          breakout freshness, VCP-like setup quality, and accumulation.
        </p>
        <div class="hero-meta">
          <span>As of {{ date }}</span>
          <span>{{ methodology.name | default('Weekly Screening', true) }}</span>
          <span>{{ methodology.total_points | default(1000, true) }} pts</span>
        </div>
      </div>

      <div class="score-card">
        <div class="score-label">Fresh Breakouts</div>
        <div class="score-value">{{ summary.fresh_breakouts | default(0, true) }}</div>
        <div class="score-sub">A+ candidates this run</div>
      </div>
    </section>

    <section class="summary-grid">
      <article class="summary-card">
        <span>Total Candidates</span>
        <strong>{{ summary.total_candidates | default(0, true) }}</strong>
      </article>
      <article class="summary-card">
        <span>Valid Items</span>
        <strong>{{ summary.valid_items | default(items|length, true) }}</strong>
      </article>
      <article class="summary-card">
        <span>Leaders</span>
        <strong>{{ summary.leaders | default(0, true) }}</strong>
      </article>
      <article class="summary-card">
        <span>Constructive Setups</span>
        <strong>{{ summary.constructive_setups | default(0, true) }}</strong>
      </article>
    </section>

    <section class="method-card">
      <div>
        <div class="section-kicker">Scoring Model</div>
        <h2>Weighted for timing, not just strength.</h2>
      </div>
      <div class="weights">
        {% for key, val in methodology.weights.items() %}
          <div class="weight-pill"><span>{{ key.replace('_', ' ') }}</span><strong>{{ val }}</strong></div>
        {% endfor %}
      </div>
    </section>

    <section class="table-section">
      <div class="section-head">
        <div>
          <div class="section-kicker">Ranked Output</div>
          <h2>Weekly Candidates</h2>
        </div>
        <div class="legend">
          <span class="dot fresh"></span>A+ Fresh Breakout
          <span class="dot leader"></span>A Leader
          <span class="dot setup"></span>B Setup
        </div>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th>Symbol</th>
              <th>Signal</th>
              <th class="num">Score</th>
              <th>Theme</th>
              <th>Source</th>
              <th class="num">Trend<br><span>/220</span></th>
              <th class="num">RS<br><span>/180</span></th>
              <th class="num">Breakout<br><span>/160</span></th>
              <th class="num">Setup<br><span>/150</span></th>
              <th class="num">Vol<br><span>/130</span></th>
              <th class="num">1M</th>
              <th class="num">3M</th>
              <th class="num">BO Days</th>
              <th class="num">From BO</th>
            </tr>
          </thead>
          <tbody>
          {% for x in items %}
            <tr class="{{ x.signal | lower | replace('+','plus') | replace(' ','-') }}">
              <td class="rank">#{{ x.rank }}</td>
              <td>
                <div class="symbol">{{ x.symbol }}</div>
                <div class="name">{{ x.name or x.trigger }}</div>
              </td>
              <td><span class="signal">{{ x.signal }}</span></td>
              <td class="num score">{{ x.weekly_score }}</td>
              <td>{{ x.theme or '—' }}</td>
              <td>{{ x.source }}</td>
              <td class="num metric-cell">
                <strong>{{ x.trend_score }}</strong>
                <div class="mini-bar"><span style="width: {{ (x.trend_score / 220 * 100) | round(0) }}%"></span></div>
              </td>
              <td class="num metric-cell">
                <strong>{{ x.rs_score }}</strong>
                <div class="sub">RS {{ x.rs_percentile }}%</div>
                <div class="mini-bar"><span style="width: {{ (x.rs_score / 180 * 100) | round(0) }}%"></span></div>
              </td>
              <td class="num metric-cell">
                <strong>{{ x.breakout_score }}</strong>
                <div class="sub">{{ x.breakout.breakout_type or '—' }}</div>
                <div class="mini-bar"><span style="width: {{ (x.breakout_score / 160 * 100) | round(0) }}%"></span></div>
              </td>
              <td class="num metric-cell">
                <strong>{{ x.setup_score }}</strong>
                {% if x.setup.vcp_like %}<div class="sub good">VCP</div>{% else %}<div class="sub">—</div>{% endif %}
                <div class="mini-bar"><span style="width: {{ (x.setup_score / 150 * 100) | round(0) }}%"></span></div>
              </td>
              <td class="num metric-cell">
                <strong>{{ x.volume_score }}</strong>
                <div class="mini-bar"><span style="width: {{ (x.volume_score / 130 * 100) | round(0) }}%"></span></div>
              </td>
              <td class="num {% if x.returns.return_1m is not none and x.returns.return_1m > 0 %}up{% elif x.returns.return_1m is not none and x.returns.return_1m < 0 %}down{% endif %}">
                {% if x.returns.return_1m is none %}—{% else %}{% if x.returns.return_1m > 0 %}+{% endif %}{{ x.returns.return_1m }}%{% endif %}
              </td>
              <td class="num {% if x.returns.return_3m is not none and x.returns.return_3m > 0 %}up{% elif x.returns.return_3m is not none and x.returns.return_3m < 0 %}down{% endif %}">
                {% if x.returns.return_3m is none %}—{% else %}{% if x.returns.return_3m > 0 %}+{% endif %}{{ x.returns.return_3m }}%{% endif %}
              </td>
              <td class="num">{{ x.breakout.days_since_breakout if x.breakout.days_since_breakout is not none else '—' }}</td>
              <td class="num">{% if x.breakout.price_from_breakout_pct is none %}—{% else %}{% if x.breakout.price_from_breakout_pct > 0 %}+{% endif %}{{ x.breakout.price_from_breakout_pct }}%{% endif %}</td>
            </tr>
            <tr class="comment-row">
              <td></td>
              <td colspan="14">
                <div class="comment">{{ x.comment }}</div>
              </td>
            </tr>
          {% else %}
            <tr><td colspan="15" class="empty">No weekly candidates yet. Add rows to data/weekly_candidates.csv and run the workflow.</td></tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </section>

    <footer class="footer">
      Generated at {{ generated_at }} · Informational only, not investment advice.
    </footer>
  </main>
</div>
</body>
</html>
