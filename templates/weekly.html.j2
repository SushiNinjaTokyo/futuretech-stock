<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock — Weekly Screening</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/weekly.css">
</head>

<body>
<div class="page">
  <div class="ambient ambient-a"></div>
  <div class="ambient ambient-b"></div>
  <div class="grid"></div>

  <main class="wrap">
    {% macro pct(v) -%}
      {% if v is none %}
        —
      {% else %}
        {% if v > 0 %}+{% endif %}{{ v | round(2) }}%
      {% endif %}
    {%- endmacro %}

    {% macro num(v, digits=0) -%}
      {% if v is none %}
        —
      {% else %}
        {{ v | round(digits) }}
      {% endif %}
    {%- endmacro %}

    {% macro score_tone(v) -%}
      {% if v is none %}
        score-neutral
      {% elif v >= 820 %}
        score-elite
      {% elif v >= 780 %}
        score-strong
      {% elif v >= 700 %}
        score-good
      {% elif v >= 620 %}
        score-watch
      {% else %}
        score-weak
      {% endif %}
    {%- endmacro %}

    {% macro signal_class(v) -%}
      {% set s = v | default('', true) %}
      {% if s.startswith('A+') %}
        signal-aplus
      {% elif s.startswith('A ') %}
        signal-a
      {% elif s.startswith('B ') %}
        signal-b
      {% elif s.startswith('C ') %}
        signal-c
      {% elif s.startswith('D ') %}
        signal-d
      {% else %}
        signal-e
      {% endif %}
    {%- endmacro %}

    {% macro yesno(v) -%}
      {% if v %}
        Yes
      {% else %}
        No
      {% endif %}
    {%- endmacro %}

    <header class="hero">
      <div class="hero-main">
        <a class="back-link" href="/">← Home</a>

        <div class="link-row">
          <a href="/daily/">Daily Top 10</a>
          <a href="/weekly-backtest/">Weekly Backtest</a>
          <a href="/weekly-simulation/">Weekly Simulation</a>
        </div>

        <div class="kicker">Weekly Screening</div>
        <h1>Weekly Signal Board</h1>

        <p>
          Minervini-inspired weekly screening for medium-term leadership, relative strength,
          breakout freshness, VCP-like setup quality, accumulation, and risk discipline.
        </p>

        <div class="policy-row">
          <span>As of {{ date }}</span>
          <span>{{ methodology.benchmark | default('SPY', true) }} benchmark context</span>
          <span>{{ methodology.total_points | default(1000, true) }} pt model</span>
          <span>Fundamentals {{ 'ON' if methodology.fundamentals_enabled else 'OFF' }}</span>
        </div>
      </div>

      <div class="status-card">
        <div class="status-label">Valid Weekly Items</div>
        <div class="status-value">
          {{ summary.valid_items | default(items | length, true) }}
        </div>
        <div class="status-sub">
          from {{ summary.total_candidates | default(0, true) }} candidates
        </div>

        <div class="status-meta">
          <div>
            <span>A+ Fresh</span>
            <strong>{{ summary.fresh_breakouts | default(0, true) }}</strong>
          </div>
          <div>
            <span>A Leaders</span>
            <strong>{{ summary.leaders | default(0, true) }}</strong>
          </div>
          <div>
            <span>B Setups</span>
            <strong>{{ summary.constructive_setups | default(0, true) }}</strong>
          </div>
          <div>
            <span>Generated</span>
            <strong>{{ payload.generated_at | default('—', true) }}</strong>
          </div>
        </div>
      </div>
    </header>

    <section class="kpi-grid">
      <article class="kpi-card">
        <div class="kpi-label">A+ Fresh Breakouts</div>
        <div class="kpi-value">
          {{ summary.fresh_breakouts | default(0, true) }}
        </div>
        <div class="kpi-note">Highest-quality fresh weekly breakout candidates</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-label">A Leaders</div>
        <div class="kpi-value">
          {{ summary.leaders | default(0, true) }}
        </div>
        <div class="kpi-note">Strong leaders that may not be fresh breakouts</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-label">B Constructive Setups</div>
        <div class="kpi-value">
          {{ summary.constructive_setups | default(0, true) }}
        </div>
        <div class="kpi-note">Constructive bases and VCP-like candidates</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-label">Model</div>
        <div class="kpi-value small">
          {{ methodology.total_points | default(1000, true) }} pts
        </div>
        <div class="kpi-note">{{ methodology.name | default('Weekly Screening', true) }}</div>
      </article>
    </section>

    {% if methodology.weights %}
    <section class="panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Scoring</div>
          <h2>Weekly Model Weights</h2>
        </div>
      </div>

      <div class="weight-grid">
        {% for key, value in methodology.weights.items() %}
        <div class="weight-card">
          <span>{{ key | replace('_', ' ') | title }}</span>
          <strong>{{ value }}</strong>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <section class="panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Signals</div>
          <h2>Weekly Candidates</h2>
        </div>
      </div>

      {% if items %}
      <div class="card-grid">
        {% for row in items %}
        <article class="stock-card">
          <div class="card-top">
            <div>
              <div class="rank-pill">#{{ row.rank | default(loop.index, true) }}</div>
              <h3>{{ row.symbol | default('—', true) }}</h3>
              <p>{{ row.name | default(row.theme, true) }}</p>
            </div>

            <div class="score-box {{ score_tone(row.weekly_score) }}">
              <span>Score</span>
              <strong>{{ row.weekly_score | default('—', true) }}</strong>
            </div>
          </div>

          <div class="signal-pill {{ signal_class(row.signal) }}">
            {{ row.signal | default('Signal', true) }}
          </div>

          <div class="theme-row">
            <span>{{ row.theme | default(row.source, true) }}</span>
            <span>{{ row.trigger | default('watch', true) }}</span>
          </div>

          <p class="comment">
            {{ row.comment | default(row.note | default('No comment available.', true), true) }}
          </p>

          <div class="score-grid">
            <div>
              <span>Trend</span>
              <strong>{{ row.trend_score | default('—', true) }}</strong>
            </div>
            <div>
              <span>RS</span>
              <strong>{{ row.rs_score | default('—', true) }}</strong>
            </div>
            <div>
              <span>RS %ile</span>
              <strong>{{ row.rs_percentile | default('—', true) }}</strong>
            </div>
            <div>
              <span>Breakout</span>
              <strong>{{ row.breakout_score | default('—', true) }}</strong>
            </div>
            <div>
              <span>Setup</span>
              <strong>{{ row.setup_score | default('—', true) }}</strong>
            </div>
            <div>
              <span>Volume</span>
              <strong>{{ row.volume_score | default('—', true) }}</strong>
            </div>
            <div>
              <span>Fundamental</span>
              <strong>{{ row.fundamental_score | default('—', true) }}</strong>
            </div>
            <div>
              <span>Risk</span>
              <strong>{{ row.risk_score | default('—', true) }}</strong>
            </div>
          </div>

          <div class="detail-grid">
            <div>
              <span>Breakout</span>
              <strong>{{ row.breakout.breakout_type | default('—', true) }}</strong>
            </div>
            <div>
              <span>Days Since BO</span>
              <strong>{{ row.breakout.days_since_breakout | default('—', true) }}</strong>
            </div>
            <div>
              <span>From BO</span>
              <strong>{{ pct(row.breakout.price_from_breakout_pct | default(none)) }}</strong>
            </div>
            <div>
              <span>BO Volume</span>
              <strong>{{ row.breakout.breakout_volume_ratio | default('—', true) }}</strong>
            </div>
            <div>
              <span>VCP-like</span>
              <strong>{{ yesno(row.setup.vcp_like | default(false)) }}</strong>
            </div>
            <div>
              <span>Extended</span>
              <strong>{{ yesno(row.risk.extended | default(false)) }}</strong>
            </div>
          </div>

          <div class="return-row">
            <div>
              <span>1W</span>
              <strong>{{ pct(row.returns.return_1w | default(none)) }}</strong>
            </div>
            <div>
              <span>1M</span>
              <strong>{{ pct(row.returns.return_1m | default(none)) }}</strong>
            </div>
            <div>
              <span>3M</span>
              <strong>{{ pct(row.returns.return_3m | default(none)) }}</strong>
            </div>
            <div>
              <span>6M</span>
              <strong>{{ pct(row.returns.return_6m | default(none)) }}</strong>
            </div>
            <div>
              <span>12M</span>
              <strong>{{ pct(row.returns.return_12m | default(none)) }}</strong>
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
      {% else %}
      <div class="empty">
        <h3>No weekly candidates available</h3>
        <p>Run weekly screening first, or check data/weekly_candidates.csv.</p>
      </div>
      {% endif %}
    </section>

    <section class="panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Table</div>
          <h2>Compact Signal List</h2>
        </div>
      </div>

      {% if items %}
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th>Symbol</th>
              <th>Name / Theme</th>
              <th>Signal</th>
              <th>Score</th>
              <th>Trend</th>
              <th>RS</th>
              <th>BO</th>
              <th>Setup</th>
              <th>Volume</th>
              <th>1M</th>
              <th>3M</th>
              <th>Extended</th>
            </tr>
          </thead>
          <tbody>
            {% for row in items %}
            <tr>
              <td>#{{ row.rank | default(loop.index, true) }}</td>
              <td><strong>{{ row.symbol | default('—', true) }}</strong></td>
              <td>
                <div class="symbol-cell">
                  <strong>{{ row.name | default('—', true) }}</strong>
                  <span>{{ row.theme | default(row.source, true) }}</span>
                </div>
              </td>
              <td><span class="signal-pill mini {{ signal_class(row.signal) }}">{{ row.signal | default('Signal', true) }}</span></td>
              <td><span class="score-pill {{ score_tone(row.weekly_score) }}">{{ row.weekly_score | default('—', true) }}</span></td>
              <td>{{ row.trend_score | default('—', true) }}</td>
              <td>{{ row.rs_score | default('—', true) }}</td>
              <td>{{ row.breakout_score | default('—', true) }}</td>
              <td>{{ row.setup_score | default('—', true) }}</td>
              <td>{{ row.volume_score | default('—', true) }}</td>
              <td>{{ pct(row.returns.return_1m | default(none)) }}</td>
              <td>{{ pct(row.returns.return_3m | default(none)) }}</td>
              <td>{{ yesno(row.risk.extended | default(false)) }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}
    </section>

    <footer class="footer">
      <div>
        <strong>Policy</strong>
        <span>
          Weekly Screening is separate from Weekly Backtest. This page ranks current weekly candidates only.
          It does not measure future outcomes. Backtest and simulation should be reviewed separately before
          changing scoring weights.
        </span>
      </div>
      <div>Generated at {{ generated_at }}</div>
    </footer>
  </main>
</div>
</body>
</html>
