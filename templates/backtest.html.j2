<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock — Filtered Signal Backtest</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/backtest.css">
</head>

<body>
<div class="page">
  <div class="ambient ambient-a"></div>
  <div class="ambient ambient-b"></div>
  <div class="grid"></div>

  <main class="wrap">
    {% macro pct(v) -%}
      {% if v is none %}
        —
      {% else %}
        {% if v > 0 %}+{% endif %}{{ v | round(2) }}%
      {% endif %}
    {%- endmacro %}

    {% macro rate(v) -%}
      {% if v is none %}
        —
      {% else %}
        {{ (v * 100) | round(1) }}%
      {% endif %}
    {%- endmacro %}

    {% macro tone(v) -%}
      {% if v is none %}
        neutral
      {% elif v > 0 %}
        up
      {% elif v < 0 %}
        down
      {% else %}
        neutral
      {% endif %}
    {%- endmacro %}

    {% macro score_tone(v) -%}
      {% if v is none %}
        score-neutral
      {% elif v >= 850 %}
        score-elite
      {% elif v >= 800 %}
        score-strong
      {% elif v >= 750 %}
        score-good
      {% elif v >= 700 %}
        score-watch
      {% else %}
        score-weak
      {% endif %}
    {%- endmacro %}

    {% macro status_text(v) -%}
      {{ v | default('pending_entry', true) | replace('_', ' ') }}
    {%- endmacro %}

    <header class="hero">
      <div class="hero-main">
        <a class="back-link" href="/">← Home</a>

        <div class="kicker">Signal Outcome Tracker</div>
        <h1>Filtered Signal Backtest</h1>

        <p>
          Tracks only qualified daily signals instead of forcing weak-market Top 3 entries.
          Entry is the next trading day’s open. Performance is fixed at 1W, 1M, and 3M,
          while current performance updates until 3M completion.
        </p>

        <div class="policy-row">
          <span>Rank ≤ 3 & Score ≥ 750</span>
          <span>Score ≥ 700 & Volume ≥ 0.55</span>
          <span>Any Rank & Score ≥ 800</span>
          <span>Entry: Next Open</span>
          <span>Stop after 3M</span>
        </div>
      </div>

      <div class="status-card">
        <div class="status-label">Filtered Signals</div>
        <div class="status-value">
          {{ summary.total_signals | default(0, true) }}
        </div>
        <div class="status-sub">tracked signals</div>

        <div class="status-meta">
          <div>
            <span>Active</span>
            <strong>{{ summary.active_signals | default(0, true) }}</strong>
          </div>
          <div>
            <span>As of</span>
            <strong>{{ summary.as_of | default('—', true) }}</strong>
          </div>
          <div>
            <span>Raw Registry</span>
            <strong>{{ summary.raw_total_signals_in_registry | default(summary.total_signals, true) }}</strong>
          </div>
          <div>
            <span>Hidden Legacy</span>
            <strong>{{ summary.hidden_legacy_signals | default(0, true) }}</strong>
          </div>
        </div>
      </div>
    </header>

    <section class="kpi-grid">
      <article class="kpi-card">
        <div class="kpi-label">Current Avg</div>
        <div class="kpi-value {{ tone(summary.avg_current_return) }}">
          {{ pct(summary.avg_current_return) }}
        </div>
        <div class="kpi-note">active until 3M completion</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-label">1W Avg Return</div>
        <div class="kpi-value {{ tone(summary.avg_return_1w) }}">
          {{ pct(summary.avg_return_1w) }}
        </div>
        <div class="kpi-note">5 trading days</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-label">1M Avg Return</div>
        <div class="kpi-value {{ tone(summary.avg_return_1m) }}">
          {{ pct(summary.avg_return_1m) }}
        </div>
        <div class="kpi-note">20 trading days</div>
      </article>

      <article class="kpi-card">
        <div class="kpi-label">3M Win Rate</div>
        <div class="kpi-value">
          {{ rate(summary.win_rate_3m) }}
        </div>
        <div class="kpi-note">completed 3M signals</div>
      </article>
    </section>

    <section class="panel coverage-panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Progress</div>
          <h2>Completion & Risk</h2>
        </div>
      </div>

      <div class="coverage-grid">
        <div class="coverage-card">
          <span>Completed 1W</span>
          <strong>{{ summary.completed_1w | default(0, true) }}</strong>
        </div>
        <div class="coverage-card">
          <span>Completed 1M</span>
          <strong>{{ summary.completed_1m | default(0, true) }}</strong>
        </div>
        <div class="coverage-card">
          <span>Completed 3M</span>
          <strong>{{ summary.completed_3m | default(0, true) }}</strong>
        </div>
        <div class="coverage-card">
          <span>Avg Max Gain</span>
          <strong class="{{ tone(summary.avg_max_gain) }}">{{ pct(summary.avg_max_gain) }}</strong>
        </div>
        <div class="coverage-card">
          <span>Avg Max DD</span>
          <strong class="{{ tone(summary.avg_max_drawdown) }}">{{ pct(summary.avg_max_drawdown) }}</strong>
        </div>
      </div>
    </section>

    {% if summary.score_buckets %}
    <section class="panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Score Quality</div>
          <h2>Performance by Score Band</h2>
        </div>
      </div>

      <div class="bucket-grid score-bucket-grid">
        {% for b in summary.score_buckets %}
        <article class="bucket-card">
          <div class="bucket-label">{{ b.label }}</div>
          <div class="bucket-main {{ tone(b.avg_current_return) }}">
            {{ pct(b.avg_current_return) }}
          </div>
          <div class="bucket-sub">Current Avg</div>

          <div class="bucket-stats">
            <div>
              <span>1W</span>
              <strong class="{{ tone(b.avg_return_1w) }}">{{ pct(b.avg_return_1w) }}</strong>
            </div>
            <div>
              <span>1M</span>
              <strong class="{{ tone(b.avg_return_1m) }}">{{ pct(b.avg_return_1m) }}</strong>
            </div>
            <div>
              <span>Count</span>
              <strong>{{ b.count }}</strong>
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if summary.rule_buckets %}
    <section class="panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Eligibility Logic</div>
          <h2>Performance by Signal Rule</h2>
        </div>
      </div>

      <div class="rule-grid">
        {% for b in summary.rule_buckets %}
        <article class="rule-card">
          <div class="rule-label">{{ b.label | replace('_', ' ') }}</div>
          <div class="rule-main {{ tone(b.avg_current_return) }}">
            {{ pct(b.avg_current_return) }}
          </div>
          <div class="rule-stats">
            <div>
              <span>1M</span>
              <strong class="{{ tone(b.avg_return_1m) }}">{{ pct(b.avg_return_1m) }}</strong>
            </div>
            <div>
              <span>3M</span>
              <strong class="{{ tone(b.avg_return_3m) }}">{{ pct(b.avg_return_3m) }}</strong>
            </div>
            <div>
              <span>Count</span>
              <strong>{{ b.count }}</strong>
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if summary.rank_buckets %}
    <section class="panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Rank Context</div>
          <h2>Performance by Rank Bucket</h2>
        </div>
      </div>

      <div class="bucket-grid">
        {% for b in summary.rank_buckets %}
        <article class="bucket-card">
          <div class="bucket-label">{{ b.label }}</div>
          <div class="bucket-main {{ tone(b.avg_current_return) }}">
            {{ pct(b.avg_current_return) }}
          </div>
          <div class="bucket-sub">Current Avg</div>

          <div class="bucket-stats">
            <div>
              <span>1M</span>
              <strong class="{{ tone(b.avg_return_1m) }}">{{ pct(b.avg_return_1m) }}</strong>
            </div>
            <div>
              <span>3M</span>
              <strong class="{{ tone(b.avg_return_3m) }}">{{ pct(b.avg_return_3m) }}</strong>
            </div>
            <div>
              <span>Count</span>
              <strong>{{ b.count }}</strong>
            </div>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <section class="panel">
      <div class="section-head">
        <div>
          <div class="section-kicker">Signals</div>
          <h2>Qualified Signal History</h2>
        </div>
      </div>

      {% if recent %}
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Rank</th>
              <th>Score</th>
              <th>Symbol</th>
              <th>Rule</th>
              <th>Entry</th>
              <th>1W</th>
              <th>1M</th>
              <th>3M</th>
              <th>Current</th>
              <th>Max Gain</th>
              <th>Max DD</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {% for row in recent %}
            <tr>
              <td>{{ row.signal_date | default('—', true) }}</td>

              <td>
                <span class="rank-pill">#{{ row.rank | default('—', true) }}</span>
              </td>

              <td>
                <span class="score-pill {{ score_tone(row.score_pts) }}">
                  {{ row.score_pts | default('—', true) }}
                </span>
              </td>

              <td>
                <div class="symbol-cell">
                  <strong>{{ row.symbol | default('—', true) }}</strong>
                  <span>{{ row.profile | default('—', true) }}</span>
                </div>
              </td>

              <td>
                <div class="rule-cell">
                  <strong>{{ row.signal_quality | default('Signal', true) }}</strong>
                  <span>{{ row.eligibility_rule | default('—', true) | replace('_', ' ') }}</span>
                </div>
              </td>

              <td>
                {% if row.entry_price is none %}
                  —
                {% else %}
                  <div class="entry-cell">
                    <strong>{{ row.entry_price | round(2) }}</strong>
                    <span>{{ row.entry_date | default('', true) }}</span>
                  </div>
                {% endif %}
              </td>

              <td class="{{ tone(row.return_1w_pct) }}">{{ pct(row.return_1w_pct) }}</td>
              <td class="{{ tone(row.return_1m_pct) }}">{{ pct(row.return_1m_pct) }}</td>
              <td class="{{ tone(row.return_3m_pct) }}">{{ pct(row.return_3m_pct) }}</td>
              <td class="{{ tone(row.current_return_pct) }}">{{ pct(row.current_return_pct) }}</td>
              <td class="{{ tone(row.max_gain_since_entry_pct) }}">{{ pct(row.max_gain_since_entry_pct) }}</td>
              <td class="{{ tone(row.max_drawdown_since_entry_pct) }}">{{ pct(row.max_drawdown_since_entry_pct) }}</td>

              <td>
                <span class="status-pill {{ row.status | default('pending_entry', true) }}">
                  {{ status_text(row.status) }}
                </span>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
      <div class="empty">
        <h3>No qualified signals yet</h3>
        <p>
          Signals will appear only when they meet the filtered eligibility rules.
          Weak-market forced rankings are intentionally excluded from this backtest view.
        </p>
      </div>
      {% endif %}
    </section>

    <footer class="footer">
      <div>
        <strong>Policy</strong>
        <span>
          Existing registry history is preserved. This view focuses on score-filtered signals.
          Legacy entries below the configured threshold may be hidden from the main summary.
        </span>
      </div>
      <div>
        Generated at {{ generated_at }}
      </div>
    </footer>
  </main>
</div>
</body>
</html>
