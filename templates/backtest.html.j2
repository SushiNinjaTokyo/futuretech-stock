<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>FutureTech Stock — Daily Event Signal Lab</title>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="stylesheet" href="/assets/backtest.css">
</head>
<body>
<div class="page"><div class="ambient a"></div><div class="ambient b"></div><div class="grid"></div>
<main class="wrap">
{% macro pct(v) -%}
  {% if v is undefined or v is none %}
    —
  {% else %}
    {% set f = v|float %}{% if f > 0 %}+{% endif %}{{ "{:.2f}".format(f) }}%
  {% endif %}
{%- endmacro %}
{% macro rate(v) -%}
  {% if v is undefined or v is none %}
    —
  {% else %}
    {{ "{:.1f}".format((v|float)*100) }}%
  {% endif %}
{%- endmacro %}
{% macro tone(v) -%}
  {% if v is undefined or v is none %}neutral{% elif v|float > 0 %}up{% elif v|float < 0 %}down{% else %}neutral{% endif %}
{%- endmacro %}
{% macro bar(label, val, maxval=50) -%}
  {% set p = 0 if val is undefined or val is none else ([100, [0, ((val|float)|abs / maxval * 100)]|max]|min) %}
  <div class="bar-row"><span>{{ label }}</span><b class="{{ tone(val) }}">{{ pct(val) }}</b><i><em style="width:{{ p }}%"></em></i></div>
{%- endmacro %}
<header class="hero">
  <a class="back" href="/">← Home</a>
  <div class="kicker">Daily Event Signal Lab</div>
  <h1>Event Backtest</h1>
  <p>Short-horizon validation for timing-sensitive daily signals: follow-through, stop risk, MFE/MAE, benchmark alpha, event archetypes, and rule comparisons.</p>
  <div class="chips"><span>Signals {{ summary.total_signals|default(0) }}</span><span>Entered {{ summary.entered_signals|default(0) }}</span><span>Pending {{ summary.pending_entries|default(0) }}</span><span>{{ payload.range.start_date|default('—') }} → {{ payload.range.end_date|default('—') }}</span></div>
</header>
<section class="kpis">
  <article><span>1D Avg</span><strong class="{{ tone(summary.avg_return_1d) }}">{{ pct(summary.avg_return_1d) }}</strong><small>next close</small></article>
  <article><span>3D Avg</span><strong class="{{ tone(summary.avg_return_3d) }}">{{ pct(summary.avg_return_3d) }}</strong><small>short follow-through</small></article>
  <article><span>5D Avg</span><strong class="{{ tone(summary.avg_return_5d) }}">{{ pct(summary.avg_return_5d) }}</strong><small>SPY α {{ pct(summary.avg_spy_alpha_5d) }} · QQQ α {{ pct(summary.avg_qqq_alpha_5d) }}</small></article>
  <article><span>10D Avg</span><strong class="{{ tone(summary.avg_return_10d) }}">{{ pct(summary.avg_return_10d) }}</strong><small>event continuation</small></article>
  <article><span>Follow-through</span><strong>{{ rate(summary.follow_through_rate) }}</strong><small>+5% within 3D</small></article>
  <article><span>Stop Hit -5%</span><strong>{{ rate(summary.stop_hit_5_rate) }}</strong><small>noise / failure rate</small></article>
  <article><span>MFE / MAE</span><strong>{{ summary.mfe_mae_ratio|default('—') }}x</strong><small>MFE {{ pct(summary.avg_mfe) }} · MAE {{ pct(summary.avg_mae) }}</small></article>
</section>
<section class="panel chart-panel">
  <div class="section-head"><div><div class="section-kicker">Signal Path</div><h2>Average Path vs SPY / QQQ</h2></div></div>
  <svg class="line-chart" viewBox="0 0 1000 320" preserveAspectRatio="none" aria-label="average path chart">
    <script type="application/json" id="path-data">{{ {'signal':payload.average_signal_path|default([], true),'spy':payload.average_spy_path|default([], true),'qqq':payload.average_qqq_path|default([], true)}|tojson }}</script>
    <polyline id="line-signal" points=""/><polyline id="line-spy" points=""/><polyline id="line-qqq" points=""/>
    <line class="zero" x1="0" x2="1000" y1="160" y2="160"/>
  </svg>
  <div class="legend"><span class="sig">Signal</span><span class="spy">SPY</span><span class="qqq">QQQ</span></div>
</section>
<section class="panel">
  <div class="section-head"><div><div class="section-kicker">Strategy Comparison</div><h2>Rule AB Test</h2></div></div>
  <div class="tabs"><button data-tab="tab-table" class="active">Table</button><button data-tab="tab-return">Return</button><button data-tab="tab-risk">Risk</button><button data-tab="tab-win">Win Rate</button></div>
  <div class="tab active" id="tab-table"><div class="table-wrap"><table><thead><tr><th>Strategy</th><th>Return</th><th>Max DD</th><th>Ret/DD</th><th>Win</th><th>Trades</th></tr></thead><tbody>{% for s in payload.strategy_comparison %}<tr><td><strong>{{ s.name }}</strong></td><td class="{{ tone(s.avg_return_pct) }}">{{ pct(s.avg_return_pct) }}</td><td class="down">{{ pct(s.max_drawdown_pct) }}</td><td>{{ s.return_drawdown_ratio|default('—') }}x</td><td>{{ rate(s.win_rate) }}</td><td>{{ s.trades|default(0) }}</td></tr>{% endfor %}</tbody></table></div></div>
  <div class="tab" id="tab-return">{% for s in payload.strategy_comparison %}{{ bar(s.name, s.avg_return_pct, 50) }}{% endfor %}</div>
  <div class="tab" id="tab-risk">{% for s in payload.strategy_comparison %}{{ bar(s.name, s.max_drawdown_pct, 20) }}{% endfor %}</div>
  <div class="tab" id="tab-win">{% for s in payload.strategy_comparison %}<div class="bar-row"><span>{{ s.name }}</span><b>{{ rate(s.win_rate) }}</b><i><em style="width:{{ 0 if s.win_rate is undefined or s.win_rate is none else (s.win_rate|float*100) }}%"></em></i></div>{% endfor %}</div>
</section>
<section class="panel split">
  <div><div class="section-kicker">Quality Matrix</div><h2>Score × Volume</h2><div class="heatmap">{% for h in payload.score_volume_heatmap %}<div class="heat"><span>{{ h.score_band }}<br>{{ h.volume_band }}</span><strong class="{{ tone(h.avg_5d) }}">{{ pct(h.avg_5d) }}</strong><small>n={{ h.count }}</small></div>{% endfor %}</div></div>
  <div><div class="section-kicker">Peak Timing</div><h2>When Winners Peak</h2>{% for p in payload.peak_distribution %}<div class="bar-row"><span>{{ p.label }}</span><b>{{ rate(p.rate) }}</b><i><em style="width:{{ 0 if p.rate is undefined or p.rate is none else (p.rate|float*100) }}%"></em></i></div>{% endfor %}</div>
</section>
<section class="panel split">
  <div><div class="section-kicker">Event Archetypes</div><h2>Profile Buckets</h2>{% for b in payload.profile_buckets %}<div class="bucket"><strong>{{ b.label }}</strong><span>{{ b.count }} signals</span><b class="{{ tone(b.avg_5d) }}">5D {{ pct(b.avg_5d) }}</b><small>FT {{ rate(b.follow_through_rate) }} · Stop {{ rate(b.stop_hit_rate) }}</small></div>{% endfor %}</div>
  <div><div class="section-kicker">Loser Diagnostics</div><h2>Failure Factors</h2>{% for d in payload.loser_diagnostics %}<div class="bar-row"><span>{{ d.label }}</span><b>{{ rate(d.rate) }}</b><i><em style="width:{{ 0 if d.rate is undefined or d.rate is none else (d.rate|float*100) }}%"></em></i></div>{% endfor %}</div>
</section>
<section class="panel">
  <div class="section-head"><div><div class="section-kicker">Signals</div><h2>Signal History</h2></div></div>
  <div class="table-wrap"><table><thead><tr><th>Date</th><th>Symbol</th><th>Triage</th><th>Score</th><th>Archetype</th><th>Entry</th><th>1D</th><th>3D</th><th>5D</th><th>10D</th><th>MFE</th><th>MAE</th><th>Peak</th><th>Status</th></tr></thead><tbody>{% for r in recent[:120] %}<tr><td>{{ r.signal_date }}</td><td><strong>{{ r.symbol }}</strong></td><td><span class="pill {{ r.triage|lower }}">{{ r.triage }}</span></td><td>{{ r.score_pts }}</td><td>{{ r.archetype }}</td><td>{{ r.entry_date|default('—') }}</td><td class="{{ tone(r.return_1d_pct) }}">{{ pct(r.return_1d_pct) }}</td><td class="{{ tone(r.return_3d_pct) }}">{{ pct(r.return_3d_pct) }}</td><td class="{{ tone(r.return_5d_pct) }}">{{ pct(r.return_5d_pct) }}</td><td class="{{ tone(r.return_10d_pct) }}">{{ pct(r.return_10d_pct) }}</td><td class="up">{{ pct(r.mfe_pct) }}</td><td class="down">{{ pct(r.mae_pct) }}</td><td>D{{ r.peak_day|default('—') }}</td><td>{{ r.status }}</td></tr>{% endfor %}</tbody></table></div>
</section>
<footer class="footer">Generated {{ generated_at }} · Daily signals are scored from isolated daily-v2 data and rendered on the primary backtest page.</footer>
</main>
</div>
<script>
(function(){
  document.querySelectorAll('[data-tab]').forEach(btn=>btn.addEventListener('click',()=>{document.querySelectorAll('[data-tab]').forEach(b=>b.classList.toggle('active',b===btn));document.querySelectorAll('.tab').forEach(p=>p.classList.toggle('active',p.id===btn.dataset.tab));}));
  const raw=document.getElementById('path-data'); if(!raw) return; let data={}; try{data=JSON.parse(raw.textContent)}catch(e){return;}
  const series=['signal','spy','qqq']; const vals=[]; series.forEach(k=>(data[k]||[]).forEach(p=>{if(p.value!==null&&p.value!==undefined) vals.push(+p.value)})); if(!vals.length)return; const min=Math.min(-5,...vals), max=Math.max(5,...vals); const x=d=>d/20*1000; const y=v=>320-((v-min)/(max-min))*280-20;
  series.forEach(k=>{const el=document.getElementById('line-'+k); if(!el)return; const pts=(data[k]||[]).filter(p=>p.value!==null&&p.value!==undefined).map(p=>`${x(p.day)},${y(+p.value)}`).join(' '); el.setAttribute('points',pts);});
})();
</script>
</body>
</html>
